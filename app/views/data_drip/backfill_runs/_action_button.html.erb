<% if backfill_run.running? %>
  <%= button_to "STOP",
  stop_backfill_run_path(backfill_run),
  method: :post,
  data: {
    confirm: "Are you sure you want to stop this backfill run?",
    disable_with: "stopping",
  },
  class: "px-4 py-2 text-white rounded font-bold shadow",
  style: "background-color: #ef4444; border: 1px solid #f97316;" %>
<% elsif backfill_run.enqueued? %>
  <%= button_to "DELETE",
  backfill_run_path(backfill_run),
  method: :delete,
  data: {
    confirm: "Are you sure you want to delete?",
    disable_with: "deleting",
  },
  class: "px-4 py-2 text-white rounded font-bold shadow",
  style: "background-color: #ef4444; border: 1px solid #dc2626;" %>
<% end %>
