<div class="min-h-screen flex bg-white"
     data-backfill-run-updates
     data-backfill-run-id="<%= @backfill_run.id %>">
  <div
    class="
      hidden md:flex flex-col m-2 justify-between w-72 bg-gradient-to-b from-slate-700
      to-gray-900 fixed inset-y-0 left-0
    "
  >
    <div class="p-6 flex justify-center items-center">
      <%= link_to backfill_runs_path, class: "block" do %>
        <span
          class="
            text-4xl font-bold tracking-widest bg-clip-text text-transparent
          "
          style="background: linear-gradient(135deg, #f72585 10%, #b5179e 50%, #7209b7 90%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-fill-color: transparent;"
        >DATADRIP
        </span>
      <% end %>
    </div>
  </div>

  <div class="flex-1 flex flex-col items-center justify-start py-10">
    <div class="w-full max-w-5xl mb-8">
      <div
        class="
          bg-gradient-to-r from-slate-700 to-gray-900 rounded-lg p-6 shadow text-white
        "
      >
        <div class="flex flex-row gap-4 mb-4">
          <div class="flex-1">
            <h1 class="text-2xl text-left"><%= @backfill_run.backfill_class_name %></h1>
            <p>by
              <%= @backfill_run.backfiller_name %></p>
          </div>
          <div class="flex-1 flex justify-end items-center" data-target="actionButton">
            <%= render 'action_button', backfill_run: @backfill_run %>
          </div>
        </div>
        <div class="flex flex-row gap-4 mt-4">
          <div class="flex-1 flex flex-col gap-1">
            <p class="text-sm font-light text-left mt-0.5">
              <span class="font-semibold">Status:</span>
              <span data-target="status">
                <%= status_tag(@backfill_run.status) %>
              </span>
            </p>
            <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Processed:</span>
              <span data-target="processedCount">
                <%= @backfill_run.processed_count %>
              </span>
              <%= if @backfill_run.amount_of_elements
                "(Maximum amount of elements: #{@backfill_run.amount_of_elements})"
              else
                ""
              end %></p>
            <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Total:</span>
              <span data-target="totalCount">
                <%= @backfill_run.total_count %>
              </span>
            </p>
            <% if @backfill_run.options.present? %>
              <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Options:</span>
                <span data-target="totalCount">
                  <% @backfill_run.options.each do |key, value| %>
                    <% next if value.blank? %>
                    <%= "#{key} = #{value}" %>
                  <% end %>
                </span>
              </p>
            <% end %>
          </div>
          <div class="flex-1 flex flex-col gap-1">
            <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Batch Size:</span>
              <%= @backfill_run.batches.first&.batch_size || @backfill_run.batch_size %></p>
            <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Created At:</span>
              <%= format_datetime_in_user_timezone(@backfill_run.created_at, @user_timezone) %>
            </p>
            <p class="text-sm font-light text-left mt-0.5"><span class="font-semibold">Starting At:</span>
              <%= format_datetime_in_user_timezone(@backfill_run.start_at, @user_timezone) %>
            </p>
          </div>

        </div>
        <div class="mt-6 pt-6 border-t border-white/15">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">
            Insights
          </h2>
          <div class="flex flex-row gap-6">
            <div class="flex-1 flex flex-col gap-1">
              <p class="text-sm font-light text-left mt-0.5">
                <span class="font-semibold">Total run time:</span>
                <span data-target="runDuration">
                  <%= format_insight_duration(@backfill_run.insight_run_duration_seconds) %>
                </span>
              </p>
              <p class="text-sm font-light text-left mt-0.5">
                <span class="font-semibold">Average time per batch:</span>
                <span data-target="averageBatchDuration">
                  <%= format_insight_duration(@backfill_run.insight_average_batch_duration_seconds) %>
                </span>
              </p>
              <p class="text-sm font-light text-left mt-0.5">
                <span class="font-semibold">Elements per second:</span>
                <span data-target="elementsPerSecond">
                  <%= format_insight_elements_per_second(@backfill_run.insight_elements_per_second) %>
                </span>
              </p>
            </div>
            <div class="flex-1 flex flex-col justify-center">
              <p class="text-sm font-semibold text-left mb-2">Progress</p>
              <progress
                data-target="progressBar"
                value="<%= @backfill_run.processed_count %>"
                max="<%= @backfill_run.total_count %>"
                class="w-full h-6 progress-bar">
              </progress>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="w-full max-w-5xl flex-1 flex flex-col">
      <div
        class="
          bg-white rounded-lg border border-gray-200 p-6 flex-1 flex flex-col
        "
      >
        <div class="flex justify-between items-center mb-6">
          <div>
            <h2 class="text-lg font-semibold text-gray-700">Batches</h2>
            <p class="text-sm text-gray-400 pt-2">Check the status of each batch</p>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">STATUS</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">BATCH SIZE</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">FINISHED AT</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">START ID</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">FINISH ID</th>
                <th class="py-2 px-4 text-gray-400 font-semibold text-sm">ERRORS</th>
              </tr>
            </thead>
            <tbody data-target="batchesTable">
              <%= render 'batches_table', backfill_run: @backfill_run, batches: @batches %>
            </tbody>
          </table>
        </div>
        
        <%= render 'data_drip/shared/pagination', 
            pagination: @batch_pagination, 
            item_name: "batches", 
            page_param: :batch_page %>
      </div>
    </div>
  </div>
</div>
